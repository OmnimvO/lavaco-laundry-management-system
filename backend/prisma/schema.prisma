generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ServiceType {
  COMPLETE_SERVICE
  WASH_AND_DRY
  WASH_ONLY
  DRY_ONLY
  DRY_AND_FOLD
  FOLD_ONLY
}

enum FulfillmentType {
  NONE
  PICKUP_ONLY
  DELIVERY_ONLY
  PICKUP_AND_DELIVERY
}

enum PaymentStatus {
  PAID
  UNPAID
}

enum OrderStatus {
  RECEIVED
  WASHING
  DRYING
  FOLDING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
}

enum EmployeePosition {
  OWNER
  MANAGER
  CASHIER
  LAUNDRY_STAFF
  DELIVERY_STAFF
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  PAYMENT_CHANGE
  PRINT
}

enum AuditEntityType {
  ORDER
  CUSTOMER
  EMPLOYEE
  REPORT
}

enum UserRole {
  ADMIN
  STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  address   String?
  createdAt DateTime @default(now())

  orders Order[]
}

model Order {
  id          Int    @id @default(autoincrement())
  orderNumber String @unique

  // Existing customer OR walk-in customer
  customerId            Int?
  walkInCustomerName    String?
  walkInCustomerPhone   String?
  walkInCustomerAddress String?

  customer Customer? @relation(fields: [customerId], references: [id])

  // Laundry weight and load calculation
  laundryWeight Float
  loadCount     Int

  hasMixedWhiteColor Boolean @default(false)
  instructions       String?

  // Laundry service
  serviceType         ServiceType
  servicePricePerLoad Float
  serviceSubtotal     Float

  // Rinse cycles
  // 2 rinses are included.
  // 3, 4, or 5 rinses have a flat ₱20 charge.
  rinseCycles Int   @default(2)
  rinseFee    Float @default(0)

  // Soap / detergent
  soapQuantity Int   @default(0)
  soapPrice    Float @default(0)

  // Fabric softener
  softenerQuantity Int   @default(0)
  softenerPrice    Float @default(0)

  // Pickup / delivery
  fulfillmentType FulfillmentType
  deliveryFee     Float           @default(0)

  // Staff
  receivedBy String?
  claimedBy  String?

  // Payment
  totalPrice    Float
  paymentStatus PaymentStatus @default(UNPAID)
  paidAt        DateTime?

  // Workflow
  status OrderStatus @default(RECEIVED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderCounter {
  id        Int @id @default(1)
  lastValue Int @default(0)
}

model Employee {
  id        Int              @id @default(autoincrement())
  firstName String
  lastName  String
  phone     String?
  address   String?
  position  EmployeePosition
  status    EmployeeStatus   @default(ACTIVE)
  dateHired DateTime
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User?
}

model AuditLog {
  id Int @id @default(autoincrement())

  action     AuditAction
  entityType AuditEntityType
  entityId   Int?
  entityName String?

  description String

  performedBy String?

  previousData Json?
  newData      Json?

  createdAt DateTime @default(now())
}

model User {
  id Int @id @default(autoincrement())

  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(STAFF)
  status       UserStatus @default(ACTIVE)

  employeeId Int?      @unique
  employee   Employee? @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShopSettings {
  id Int @id @default(1)

  shopName      String @default("Lava Co. Laundry Hub")
  shopAddress   String?
  contactNumber String?
  receiptFooter String @default("Thank you for choosing Lava Co. Laundry Hub!")

  completeServicePrice Float @default(150)
  washAndDryPrice      Float @default(120)
  washOnlyPrice        Float @default(70)
  dryOnlyPrice         Float @default(70)
  dryAndFoldPrice      Float @default(100)
  foldOnlyPrice        Float @default(40)

  extraRinseFee Float @default(20)

  soapPrice     Float @default(20)
  softenerPrice Float @default(15)

  pickupOnlyFee       Float @default(0)
  deliveryOnlyFee     Float @default(0)
  pickupAndDeliveryFee Float @default(0)

  maximumWeightPerLoad Float @default(8)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}