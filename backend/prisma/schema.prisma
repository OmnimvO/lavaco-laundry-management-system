generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ServiceType {
  COMPLETE_SERVICE
  WASH_AND_DRY
  WASH_ONLY
  DRY_ONLY
  DRY_AND_FOLD
  FOLD_ONLY
}

enum FulfillmentType {
  NONE
  PICKUP_ONLY
  DELIVERY_ONLY
  PICKUP_AND_DELIVERY
}

enum PaymentStatus {
  PAID
  UNPAID
}

enum OrderStatus {
  RECEIVED
  WASHING
  DRYING
  FOLDING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  address   String?
  createdAt DateTime @default(now())

  orders Order[]
}

model Order {
  id          Int    @id @default(autoincrement())
  orderNumber String @unique

  // Existing customer OR walk-in customer
  customerId            Int?
  walkInCustomerName    String?
  walkInCustomerPhone   String?
  walkInCustomerAddress String?

  customer Customer? @relation(fields: [customerId], references: [id])

  // Laundry weight and load calculation
  laundryWeight Float
  loadCount     Int

  hasMixedWhiteColor Boolean @default(false)
  instructions       String?

  // Laundry service
  serviceType         ServiceType
  servicePricePerLoad Float
  serviceSubtotal     Float

  // Rinse cycles
  // 2 rinses are included.
  // 3, 4, or 5 rinses have a flat ₱20 charge.
  rinseCycles Int   @default(2)
  rinseFee    Float @default(0)

  // Soap / detergent
  soapQuantity Int   @default(0)
  soapPrice    Float @default(0)

  // Fabric softener
  softenerQuantity Int   @default(0)
  softenerPrice    Float @default(0)

  // Pickup / delivery
  fulfillmentType FulfillmentType
  deliveryFee     Float           @default(0)

  // Staff
  receivedBy String?
  claimedBy  String?

  // Payment
  totalPrice    Float
  paymentStatus PaymentStatus @default(UNPAID)

  // Workflow
  status OrderStatus @default(RECEIVED)

  createdAt DateTime @default(now())
}

model OrderCounter {
  id        Int @id @default(1)
  lastValue Int @default(0)
}
