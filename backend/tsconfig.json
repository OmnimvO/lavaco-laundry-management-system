{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,

    "moduleResolution": "NodeNext",

    "types": [
      "node",
      "express"
    ],

    "skipLibCheck": true
  },

  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "prisma.config.ts"
  ]
}